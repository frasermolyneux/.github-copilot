{
  "folders": [
    {
      "name": ".github-copilot",
      "path": "."
    },
    {
      "name": "portal-core",
      "path": "../portal-core"
    },
    {
      "name": "portal-environments",
      "path": "../portal-environments"
    },
    {
      "name": "portal-repository",
      "path": "../portal-repository"
    },
    {
      "name": "portal-repository-func",
      "path": "../portal-repository-func"
    },
    {
      "name": "portal-server-agent",
      "path": "../portal-server-agent"
    },
    {
      "name": "portal-server-events",
      "path": "../portal-server-events"
    },
    {
      "name": "portal-servers-integration",
      "path": "../portal-servers-integration"
    },
    {
      "name": "portal-sync",
      "path": "../portal-sync"
    },
    {
      "name": "portal-web",
      "path": "../portal-web"
    },
    {
      "path": "../.github"
    }
  ],
  "settings": {
    "chat.promptFiles": true,
    "chat.agent.enabled": true,
    "chat.promptFilesLocations": {
      "./.github/prompts": true
    },
    "chat.instructionsFilesLocations": {
      "./.github/instructions": true,
      "./.github": true
    },
    "chat.agentFilesLocations": {
      "./.github/agents": true
    },
    "chat.tools.terminal.autoApprove": {
      "dotnet format": true,
      "/^Set-Location c:\\\\Git\\\\gh-frasermolyneux\\\\portal-web; dotnet --version$/": {
        "approve": true,
        "matchCommandLine": true
      }
    }
  },
  "extensions": {
    "recommendations": [
      "github.copilot",
      "github.copilot-chat"
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "MCP: Install local catalog server",
        "type": "shell",
        "command": "npm run install-local",
        "options": {
          "cwd": "${workspaceFolder:.github-copilot}/mcp-server"
        },
        "problemMatcher": []
      },
      {
        "label": "MCP: Reinstall local catalog server (skip build)",
        "type": "shell",
        "command": "npm run install-local -- --SkipBuild",
        "options": {
          "cwd": "${workspaceFolder:.github-copilot}/mcp-server"
        },
        "problemMatcher": []
      }
    ]
  }
}