{
  "name": "frasermolyneux-copilot-mcp-server",
  "version": "0.1.0",
  "description": "stdio MCP server exposing the frasermolyneux/.github-copilot instruction, prompt, agent, and skill catalog to MCP-capable clients (VS Code, Copilot CLI/App, Claude Desktop, etc.).",
  "type": "module",
  "bin": {
    "gh-copilot-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "smoke": "node scripts/smoke.mjs",
    "install-local": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/install-local.ps1"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "private": true
}